[Unit]
Description=ClawX Web Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/clawx-web
Environment="NODE_ENV=production"
Environment="PORT=2003"
Environment="HOST=0.0.0.0"
ExecStart=/usr/bin/node /root/clawx-web/dist-server/index.js
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
